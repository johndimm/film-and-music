{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@film-music/constellations": ["../../packages/constellations"],
      "@film-music/constellations/*": ["../../packages/constellations/*"],
      "@film-music/platform": ["../../packages/film-music-platform/src"],
      "@film-music/platform/*": ["../../packages/film-music-platform/src/*"],
      "@film-music/taste-context": ["../../packages/taste-context/src"],
      "@film-music/taste-context/*": ["../../packages/taste-context/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/*/src/**/*.ts",
    "../../packages/*/src/**/*.tsx",
    "../../packages/constellations/*.ts",
    "../../packages/constellations/*.tsx",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "../../packages/constellations/server.ts",
    "../../packages/constellations/scripts/**/*"
  ]
}
