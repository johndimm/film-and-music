{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@film-music/constellations": ["app/lib/constellations/index.tsx"],
      "@film-music/constellations/*": ["app/lib/constellations/*"],
      "@film-music/platform": ["app/lib/platform/index.ts"],
      "@film-music/platform/*": ["app/lib/platform/*"],
      "@film-music/taste-context": ["app/lib/taste-context/index.ts"],
      "@film-music/taste-context/*": ["app/lib/taste-context/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
